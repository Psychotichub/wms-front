# Choose environment
# EXPO_PUBLIC_APP_ENV=development
# EXPO_PUBLIC_APP_ENV=production

# Option A (simple): single API URL for all envs
# EXPO_PUBLIC_API_URL=http://localhost:4000

# Admin signup (development only):
# If set, Signup will send this to backend; backend must also set ADMIN_SIGNUP_CODE to the same value.
# EXPO_PUBLIC_ADMIN_SIGNUP_CODE=replace_me

# Web Push (browser push) - public VAPID key
# This is safe to expose to the client.
# EXPO_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=replace_me

# Option B (recommended): per-environment values
# Dev backend (your local backend on 4000)
# EXPO_PUBLIC_API_URL_DEV=http://localhost:4000
# Android emulator dev backend
# EXPO_PUBLIC_API_URL_DEV=http://10.0.2.2:4000

# Prod backend
# EXPO_PUBLIC_API_URL_PROD=https://ewms-k9l2.onrender.com

# Notes:
# - Expo web runs on http://localhost:8081 (frontend), but API is still http://localhost:4000
