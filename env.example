# =============================================================================
# WMS Frontend (Expo) — public environment template
# Copy to `.env`. Variables prefixed EXPO_PUBLIC_* are inlined at build time.
# Set the same keys in EAS / CI / Render Static when you export web.
# =============================================================================
#
# Your production reference:
#   Web app:   https://psychotic.expo.app
#   Backend:   https://ewms-k9l2.onrender.com
#
# ----------------------------------------------------------------------------- 
# API (required for app to talk to backend)
# ----------------------------------------------------------------------------- 
# Option A — single URL for all builds (simplest for production web export):
EXPO_PUBLIC_API_URL=https://ewms-k9l2.onrender.com

# Option B — switch by app environment (see src/config/env.ts):
# EXPO_PUBLIC_APP_ENV=development
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_API_URL_DEV=http://localhost:4000
# Android emulator → host machine:
# EXPO_PUBLIC_API_URL_DEV=http://10.0.2.2:4000
# EXPO_PUBLIC_API_URL_PROD=https://ewms-k9l2.onrender.com

# ----------------------------------------------------------------------------- 
# Optional
# ----------------------------------------------------------------------------- 
# Must match backend ADMIN_SIGNUP_CODE when bootstrapping an admin via Sign up.
# Remove or leave empty in production after admins exist.
# EXPO_PUBLIC_ADMIN_SIGNUP_CODE=

# Browser push — public VAPID key only (private key lives on backend).
# EXPO_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=

# Error reporting (matches @sentry/react-native / sentry.ts)
# EXPO_PUBLIC_SENTRY_DSN=

# ----------------------------------------------------------------------------- 
# EAS / release builds
# ----------------------------------------------------------------------------- 
# eas.json may set SENTRY_DISABLE_AUTO_UPLOAD=true so iOS/Android build without Sentry CLI.
# To upload source maps: add EAS secrets (SENTRY_AUTH_TOKEN) and adjust eas.json per
# https://docs.sentry.io/platforms/react-native/manual-setup/
