# Baked into the web bundle at build time (Expo: EXPO_PUBLIC_*).
# Set the same variables in:
# - Render Static Site → Environment (for `npm run export:web` on CI)
# - EAS / local shell when running: npm run export:web && eas deploy

EXPO_PUBLIC_API_URL=https://your-api.onrender.com

# Optional
# EXPO_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
# EXPO_PUBLIC_ADMIN_SIGNUP_CODE=
# EXPO_PUBLIC_ENABLE_LOCATION_PAGES=false
# EXPO_PUBLIC_SENTRY_DSN=
