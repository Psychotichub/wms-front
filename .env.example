# Baked into the web bundle at build time (Expo: EXPO_PUBLIC_*).
# Set the same variables in:
# - Render Static Site → Environment (for `npm run export:web` on CI)
# - EAS / local shell when running: npm run export:web && eas deploy

EXPO_PUBLIC_API_URL=https://your-api.onrender.com

# Optional
# EXPO_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
# EXPO_PUBLIC_ADMIN_SIGNUP_CODE=
# EXPO_PUBLIC_ENABLE_LOCATION_PAGES=false
# EXPO_PUBLIC_SENTRY_DSN=
#
# EAS native builds: @sentry/react-native runs sentry-cli to upload source maps on release.
# eas.json sets SENTRY_DISABLE_AUTO_UPLOAD=true so Android/iOS builds succeed without Sentry org/token.
# To upload maps: remove that env from eas.json profiles and add EAS Secrets (SENTRY_AUTH_TOKEN) plus
# org/project per https://docs.sentry.io/platforms/react-native/manual-setup/
